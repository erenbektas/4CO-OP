{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "4CO-OP Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "models",
    "tags",
    "monitor_window",
    "logging"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planner",
        "builder",
        "spec_checker",
        "escalation",
        "reviewer",
        "fixer",
        "gatekeeper",
        "narrator"
      ],
      "properties": {
        "planner": { "$ref": "#/definitions/modelConfig" },
        "builder": { "$ref": "#/definitions/modelConfig" },
        "spec_checker": { "$ref": "#/definitions/modelConfig" },
        "escalation": { "$ref": "#/definitions/modelConfig" },
        "reviewer": { "$ref": "#/definitions/modelConfig" },
        "fixer": { "$ref": "#/definitions/modelConfig" },
        "gatekeeper": { "$ref": "#/definitions/modelConfig" },
        "narrator": { "$ref": "#/definitions/modelConfig" },
        "pr_writer": { "$ref": "#/definitions/modelConfig" }
      }
    },
    "tags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meta",
        "planner",
        "builder",
        "spec_checker",
        "escalation",
        "reviewer",
        "fixer",
        "gatekeeper",
        "narrator"
      ],
      "properties": {
        "meta": { "type": "string", "minLength": 1 },
        "planner": { "type": "string", "minLength": 1 },
        "builder": { "type": "string", "minLength": 1 },
        "spec_checker": { "type": "string", "minLength": 1 },
        "escalation": { "type": "string", "minLength": 1 },
        "reviewer": { "type": "string", "minLength": 1 },
        "fixer": { "type": "string", "minLength": 1 },
        "gatekeeper": { "type": "string", "minLength": 1 },
        "narrator": { "type": "string", "minLength": 1 },
        "pr_writer": { "type": "string", "minLength": 1 }
      }
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["in_place", "worktree"],
          "default": "in_place",
          "description": "Where the pipeline does its work. 'in_place' (default) creates a feat/<slug> branch in the current repo and autostashes any uncommitted changes. 'worktree' creates a sibling git worktree."
        }
      }
    },
    "monitor_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "port",
        "auto_launch",
        "browser"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "auto_launch": { "type": "boolean" },
        "browser": {
          "type": "string",
          "minLength": 1,
          "default": "system",
          "description": "Browser launcher preference. Defaults to 'system', which opens the tracker in the OS default browser. Use 'auto' to prefer an app-style window via Chrome/Edge/Brave if installed, or pass a browser name/path such as edge, chrome, brave, or an executable path."
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "dir",
        "snapshot_interval_seconds_active",
        "snapshot_interval_seconds_idle"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "dir": { "type": "string", "minLength": 1 },
        "snapshot_interval_seconds_active": {
          "type": "integer",
          "minimum": 1
        },
        "snapshot_interval_seconds_idle": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "suspend": {
      "type": "object",
      "additionalProperties": false,
      "description": "Controls auto-suspend, heartbeat, and resume behavior for long-running stages.",
      "properties": {
        "auto_suspend_on_network_loss": {
          "type": "boolean",
          "default": true,
          "description": "When true, the watchdog auto-suspends if a stage stream goes silent and the network probe fails."
        },
        "auto_resume_on_recovery": {
          "type": "boolean",
          "default": false,
          "description": "When true, auto-suspended runs (network_loss only) auto-resume once the network probe recovers."
        },
        "stream_silence_timeout_ms": {
          "type": "integer",
          "minimum": 10000,
          "default": 90000,
          "description": "Duration of stream silence before the watchdog probes the network."
        },
        "network_probe_endpoints": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "default": [
            "https://api.anthropic.com",
            "https://api.openai.com"
          ]
        },
        "max_consecutive_probe_failures": {
          "type": "integer",
          "minimum": 1,
          "default": 3
        },
        "lock_heartbeat_interval_ms": {
          "type": "integer",
          "minimum": 1000,
          "default": 10000
        },
        "lock_heartbeat_stale_ms": {
          "type": "integer",
          "minimum": 10000,
          "default": 120000
        }
      }
    }
  },
  "definitions": {
    "modelConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cli",
        "model",
        "tag_display"
      ],
      "properties": {
        "cli": {
          "type": "string",
          "enum": [
            "claude",
            "codex"
          ]
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string"
        },
        "tag_display": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
