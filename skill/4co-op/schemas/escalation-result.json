{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resolved",
    "tagged_message"
  ],
  "properties": {
    "resolved": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "evidence_file",
          "evidence_line",
          "quote"
        ],
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL"] },
          "evidence_file": { "type": "string" },
          "evidence_line": { "type": "integer", "minimum": 1 },
          "quote": { "type": "string" }
        }
      }
    },
    "tagged_message": { "type": "string" }
  }
}
