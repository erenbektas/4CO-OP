{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issues",
    "tagged_message",
    "body_markdown"
  ],
  "properties": {
    "issues": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "text"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "important", "minor"]
          },
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "text": { "type": "string" }
        }
      }
    },
    "tagged_message": { "type": "string" },
    "body_markdown": { "type": "string" }
  }
}
