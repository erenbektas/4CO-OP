{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "severity",
    "issues"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["APPROVE", "REJECT"]
    },
    "severity": {
      "type": "string",
      "enum": ["CRITICAL", "IMPORTANT", "MINOR", "NONE"]
    },
    "issues": {
      "type": "array",
      "maxItems": 5,
      "items": { "type": "string" }
    }
  }
}
