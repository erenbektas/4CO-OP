{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "files_changed",
    "tests_added",
    "build",
    "tests",
    "lint",
    "commit_sha",
    "commit_message",
    "notes"
  ],
  "properties": {
    "session_id": { "type": "string" },
    "files_changed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tests_added": {
      "type": "array",
      "items": { "type": "string" }
    },
    "build": { "type": "string" },
    "tests": { "type": "string" },
    "lint": { "type": "string" },
    "commit_sha": { "type": "string" },
    "commit_message": { "type": "string" },
    "notes": { "type": "string" }
  }
}
